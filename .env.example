# --- Server-side only (Netlify Functions / environment variables) ---
# The browser holds none of these — this is a single-user instance gated
# by Netlify Password Protection, not Supabase Auth. Never prefix these
# with VITE_ — that would expose them to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Fixed UUID seeded by supabase/migrations/0001_init_profiles_and_pillars.sql
PRIMARY_USER_ID=11111111-1111-1111-1111-111111111111

AI_API_KEY=
# ^ Your Anthropic API key. Now actually used by
#   netlify/functions/horoscope.ts (calls api.anthropic.com directly) —
#   this is reserved but unused everywhere else until Phase 4's Morning
#   Intelligence AI summary pipeline.
MARKET_DATA_API_KEY=
SPORTS_DATA_API_KEY=
NEWS_API_KEY=

# Weather uses the free National Weather Service API (no key needed) —
# see netlify/functions/weather.ts. NWS just requires a descriptive
# User-Agent identifying the app + a contact method, not a secret.
NWS_USER_AGENT=RDP 2.0 personal app (contact: your-email@example.com)

# iCloud Calendar (CalDAV) — the one live calendar connector in Phase 2.
# Generate an APP-SPECIFIC password at https://appleid.apple.com →
# Sign-In and Security → App-Specific Passwords. Do NOT use your real
# Apple ID password here. See docs/INTEGRATIONS.md.
ICLOUD_APPLE_ID=
ICLOUD_APP_SPECIFIC_PASSWORD=

# Google Calendar / Outlook Calendar: not implemented yet — both require
# an OAuth app registration you create yourself before any code can use
# these. See netlify/functions/calendar-sync-google.ts /
# calendar-sync-outlook.ts and docs/INTEGRATIONS.md.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

APP_URL=
