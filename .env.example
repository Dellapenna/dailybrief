# --- Server-side only (Netlify Functions / environment variables) ---
# The browser holds none of these — this is a single-user instance gated
# by Netlify Password Protection, not Supabase Auth. Never prefix these
# with VITE_ — that would expose them to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Fixed UUID seeded by supabase/migrations/0001_init_profiles_and_pillars.sql
PRIMARY_USER_ID=11111111-1111-1111-1111-111111111111

AI_API_KEY=
MARKET_DATA_API_KEY=
SPORTS_DATA_API_KEY=
NEWS_API_KEY=
WEATHER_API_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

APP_URL=
